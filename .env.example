# ===== Discord =====
# Токен бота из Developer Portal (Bot -> Reset Token).
DISCORD_BOT_TOKEN=

# ID каналов через запятую. Оставь пустым на бою — бот слушает шесть боевых
# каналов проекта из src/channelRules.js. Заполнять только для теста на другом сервере.
DISCORD_CHANNEL_IDS=

# ===== Связь с сайтом «Следак» (HTTP API) =====
# Единственный канал связи бот <-> сайт: эндпоинт /api/bot. Прямого доступа к БД у бота НЕТ.
# Бот шлёт события Discord и забирает очередь публикаций через этот URL с токеном.
BOT_API_URL=https://sledak-rmrp.ru/api/bot
# Общий секрет: та же строка должна стоять в переменных Vercel (BOT_API_SECRET). Обязателен.
BOT_API_SECRET=
# Управление, от имени которого работает этот экземпляр бота: arbat/rublevka/patriki/tverskoy/kutuzovsky/ca.
# Обязательно для мультипортальности, чтобы события без номера дела не попадали в старое управление по умолчанию.
BOT_UNIT=

# BOT_UNIT автоматически уходит в X-Sledak-Key-Id. Для ЦА: ca.

# ===== Публикация в Discord =====
# Каналы должны быть заданы для всех используемых типов. Пустой канал больше не
# считается успешной публикацией: job получит NACK и после 5 ошибок уйдёт в DLQ.
# ID канала еженедельного отчёта (доступ — руководитель + ты).
REPORT_CHANNEL_ID=
# ПГСкО пока ведётся только на портале. Явно включай обе строки лишь при
# согласованном возврате Discord-публикаций и реакций.
PGSKO_DISCORD_ENABLED=false
# ID канала, куда бот публикует отчёты ПГСкО.
PGSKO_REPORT_CHANNEL_ID=
# ID канала «акты-и-делоодобрение» — уведомления о поданных на проверку актах по делам.
ACT_REVIEW_CHANNEL_ID=1498065990888718376
# ID канала задач КСУ. КСУ относится к отдельному серверу ЦА:
# в экземпляре Арбата оставь пустым, в BOT_UNIT=ca укажи канал ЦА.
KSO_TASKS_CHANNEL_ID=
# Для второго сервера переопредели каналы публикаций его собственными ID.
CASES_CHANNEL_ID=
ROSTER_CHANNEL_ID=
# ID канала уведомлений о взысканиях.
DISCIPLINE_CHANNEL_ID=
# Старые каналы дел, из которых бот вправе удалять собственные публикации после
# переноса канала. Только явный allowlist, через запятую.
CASES_LEGACY_CHANNEL_IDS=
# ID роли, чья ✅ засчитывает ПГСкО. Fail-closed: пусто = реакции игнорируются.
PGSKO_APPROVER_ROLE_ID=
# ID роли прокуратуры — упоминается в делах и нужна для архивации по реакции.
PROSECUTOR_ROLE_ID=
# ID роли, чья ✅ одобряет рапорт на отпуск. Fail-closed: пусто = реакции игнорируются.
VACATION_APPROVER_ROLE_ID=
# Allowlist авторов сообщений состава (Discord ID через запятую).
# Пусто = любые авторы (полагаемся на права канала «состав-ск»).
STAFF_ALLOWED_AUTHOR_IDS=

# Для нескольких управлений на одном host можно использовать префикс управления,
# например TVERSKOY_CASES_CHANNEL_ID. Non-Arbat не наследует ID/роли/эмодзи Арбата.
# Кастомные Discord role/emoji maps для текущего сервера (JSON object).
POSITION_ROLE_IDS_JSON={}
RANK_EMOJI_JSON={}
EMBED_FOOTER=

# ===== OCR кадровых приказов («внутренний-оборот») =====
# Fail-closed: OCR выключен даже при сохранённом ключе, пока здесь не указано true.
OCR_ENABLED=false
# Ключ aitunnel (OpenAI-совместимый API). Используется только при OCR_ENABLED=true.
OCR_API_KEY=
OCR_BASE_URL=https://api.aitunnel.ru/v1
OCR_MODEL=claude-haiku-4.5

# ===== Прочее =====
# Включай только если в Discord Developer Portal включён Server Members Intent.
# Нужен для упоминания сотрудников по нику при публикации состава.
DISCORD_ENABLE_GUILD_MEMBERS=false
OUTPUT_DIR=./logs
LOG_RAW_MESSAGES=false
IGNORE_BOTS=true
LOG_LEVEL=info
HTTP_TIMEOUT_MS=7000
# SHA реально развёрнутого коммита. Печатается в стартовом логе, чтобы сразу
# отличать актуальную сборку от старого контейнера.
APP_RELEASE=
# Необязательно. Для второго экземпляра (ЦА) задайте dsbot-ca,
# чтобы имя контейнера не пересеклось с экземпляром Арбата.
BOT_CONTAINER_NAME=dsbot-arbat
