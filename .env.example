# ===== Discord =====
# Токен бота из Developer Portal (Bot -> Reset Token).
DISCORD_BOT_TOKEN=

# ID каналов через запятую. Оставь пустым на бою — бот слушает шесть боевых
# каналов проекта из src/channelRules.js. Заполнять только для теста на другом сервере.
DISCORD_CHANNEL_IDS=

# ===== Связь с таблицей (Apps Script Web App) =====
# URL веб-приложения вида https://script.google.com/macros/s/.../exec
OUTPUT_WEBHOOK_URL=

# Общий секрет — должен совпадать со Script Property WEBHOOK_SECRET в таблице.
WEBHOOK_SECRET=

# ===== Хранилище =====
# apps_script = старый режим через Google Apps Script
# postgres = новый режим через Neon/Postgres
# both = писать и в Apps Script, и в Postgres (только для аккуратного переходного теста)
BOT_STORAGE=apps_script

# Neon connection string. Required when BOT_STORAGE=postgres/both.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# ===== Публикация в Discord =====
# ID канала еженедельного отчёта (доступ — руководитель + ты). Заполнить, когда канал создадут.
REPORT_CHANNEL_ID=
# ID канала, куда бот публикует отчёты ПГСкО из Google Forms.
PGSKO_REPORT_CHANNEL_ID=
# ID канала «акты-и-делоодобрение» — уведомления о поданных на проверку актах по делам.
ACT_REVIEW_CHANNEL_ID=1498065990888718376
# Опционально: ID роли, чья ✅ засчитывает ПГСкО. Пусто = любая не-ботская ✅.
PGSKO_APPROVER_ROLE_ID=
# ID роли прокуратуры — упоминается в делах и нужна для архивации по реакции.
PROSECUTOR_ROLE_ID=

# ===== OCR кадровых приказов («внутренний-оборот») =====
# Ключ aitunnel (OpenAI-совместимый API). Пусто = OCR выключен, картинки только логируются.
OCR_API_KEY=
OCR_BASE_URL=https://api.aitunnel.ru/v1
OCR_MODEL=claude-haiku-4.5

# ===== Прочее =====
OUTPUT_DIR=./logs
IGNORE_BOTS=true
LOG_LEVEL=info
HTTP_TIMEOUT_MS=7000
